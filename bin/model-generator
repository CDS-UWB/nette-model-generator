#!/usr/bin/env php
<?php

declare(strict_types=1);

require_once $_composer_autoload_path ?? __DIR__ . '/../vendor/autoload.php';

use Cds\NetteModelGenerator\FileWriter;
use Cds\NetteModelGenerator\GeneratorContext;
use Cds\NetteModelGenerator\ModelGenerator;
use Cds\NetteModelGenerator\Psr4FileManager;
use Cds\NetteModelGenerator\Reflections\MySqlReflection;
use Cds\NetteModelGenerator\Reflections\PostgreSqlReflection;

const AllowedDrivers = ['mysql', 'pgsql'];

$options = getopt(
    short_options: 'd:n:s:ir:e:o:H:D:U:P:p:h',
    long_options: [
        'driver:',
        'schemas:',
        'include-schema',
        'root-dir:',
        'namespace:',
        'omit-namespace-root:',
        'host:',
        'dbname:',
        'user:',
        'password:',
        'port:',
        'help',
    ],
);

if (isset($options['h']) || isset($options['help'])) {
    printHelp();

    exit(0);
}

$driver = $options['d'] ?? $options['driver'] ?? null;
if (!in_array($driver, AllowedDrivers, true)) {
    printError('Invalid or missing database driver. Allowed drivers are: ' . implode(', ', AllowedDrivers));
    printHelp();

    exit(1);
}

$rootDir = $options['r'] ?? $options['root-dir'] ?? null;
if ($rootDir === null) {
    printError('Missing root directory for generated files.');
    printHelp();

    exit(1);
}

$host = $options['H'] ?? $options['host'] ?? null;
if ($host === null) {
    printError('Missing database host.');
    printHelp();

    exit(1);
}

$dbname = $options['D'] ?? $options['dbname'] ?? null;
if ($dbname === null) {
    printError('Missing database name.');
    printHelp();

    exit(1);
}

$user = $options['U'] ?? $options['user'] ?? null;
if ($user === null) {
    printError('Missing database user.');
    printHelp();

    exit(1);
}

$password = $options['P'] ?? $options['password'] ?? null;
if ($password === null) {
    printError('Missing database password.');
    printHelp();

    exit(1);
}

$namespace = $options['e'] ?? $options['namespace'] ?? null;
$omitNamespaceRootInPath = $options['o'] ?? $options['omit-namespace-root'] ?? null;
if ($omitNamespaceRootInPath !== null && !str_contains($namespace, $omitNamespaceRootInPath)) {
    printError('Namespace root must be a part of the namespace.');
    printHelp();

    exit(1);
}

// Prepare a connection to the database.
$port = $options['port'] ?? null;
$connection = new Nette\Database\Connection(
    dsn: "{$driver}:host={$host};dbname={$dbname}" . ($port !== null ? ";port={$port}" : ''),
    user: $user,
    password: $password,
);

// Prepare a context for the generator.
$context = new GeneratorContext(
    reflection: match ($driver) {
        'mysql' => new MySqlReflection(
            connection: $connection,
            dbName: $dbname
        ),
        'pgsql' => new PostgreSqlReflection(
            connection: $connection,
            dbName: $dbname,
            schemas: parseSchemas($options['s'] ?? $options['schemas'] ?? null)
        ),
    },
    fileManager: new Psr4FileManager(
        rootDir: parseRootDir($rootDir),
        namespace: parseNamespace($namespace),
        includeSchema: isset($options['i']) || isset($options['include-schema']),
        omitNamespaceRootInPath: $omitNamespaceRootInPath,
    ),
    fileWriter: new FileWriter(),
    printer: new Nette\PhpGenerator\PsrPrinter(),
);

// Create a new instance of the model generator.
$generator = new ModelGenerator();

// Run generator with default generators.
$files = iterator_to_array($generator->runDefault($context), false);

$changed = count($files);

echo "Changed {$changed} files:\n";

foreach ($files as $filePath) {
    echo "\t{$filePath}\n";
}

/**
 * @return list<string>
 */
function parseSchemas(string|null $schemas): array
{
    if ($schemas === null) {
        return [];
    }

    return array_map('trim', explode(',', $schemas));
}

/**
 * @return list<string>
 */
function parseRootDir(string $rootDir): array
{
    if (str_ends_with($rootDir, '/')) {
        $rootDir = substr($rootDir, 0, -1);
    }

    return explode('/', $rootDir);
}

/**
 * @return list<string>
 */
function parseNamespace(string|null $namespace): array
{
    if ($namespace === null) {
        return ['App', 'Model'];
    }

    return explode('\\', $namespace);
}

function printHelp(): void
{
    echo <<<HELP
    Usage: model-generator -d <mysql|pgsql> -H <host> -D <dbname> -U <user> -P <password> [optional options]
    Options:
      Required:
        -d, --driver    Database driver (e.g., mysql, pgsql).
        -H, --host      Database host.
        -D, --dbname    Database name.
        -U, --user      Database user.
        -P, --password  Database password.
        -r, --root-dir  Root directory for generated files.

      Optional:
        -p, --port                 Database port.
        -s, --schemas              [pgsql only] Comma-separated list of schemas to include (optional).
        -i, --include-schema       [pgsql only] Include schema name in generated class names and paths (optional).
        -e, --namespace            Namespace for generated classes (default: App\\Model).
        -o, --omit-namespace-root  Namespace part ignored when generating PSR-4 structure for model (optional).

      -h, --help      Display this help message.\n
    HELP;
}

function printError(string $message): void
{
    echo "\033[31mError: {$message}\033[0m\n\n";
}
